# Containerfile for azure-mcp-server
#
# Works around the broken --dangerously-disable-http-incoming-auth flag
# by running the Azure MCP binary in stdio mode behind a lightweight
# Python HTTP proxy.  The proxy exposes unauthenticated HTTP so that
# the ARO partner agent can call Azure tools without JWT configuration.
#
# The official MCR binary is musl-linked (Alpine), so we use a Python
# Alpine image to match.
#
# Build context: project root (same as other services)

# Stage 1 — grab the Azure MCP binary from the official Microsoft image
FROM mcr.microsoft.com/azure-sdk/azure-mcp:latest AS mcp-binary

# Stage 2 — Python runtime with the HTTP proxy (Alpine to match musl binary)
FROM python:3.12-alpine

# Install runtime dependencies for the .NET binary
RUN apk add --no-cache libstdc++ libgcc icu-libs curl

WORKDIR /mcp-server

# Copy the Azure MCP binary and its runtime from the official image
COPY --from=mcp-binary /mcp-server/ /mcp-server/

# Install Python dependencies for the proxy
RUN pip install --no-cache-dir aiohttp mcp

# Copy the proxy script
COPY azure-mcp-server/mcp_proxy.py /mcp-server/mcp_proxy.py

# .NET runtime needs writable dirs
RUN mkdir -p /tmp/.net /tmp/.cache /tmp/.aspnet && \
    chmod -R 777 /tmp/.net /tmp/.cache /tmp/.aspnet && \
    chgrp -R 0 /mcp-server && chmod -R g=u /mcp-server

# Run as non-root
RUN adduser -D -u 1001 mcp-proxy
USER 1001

ENV HOME=/tmp
ENV XDG_CACHE_HOME=/tmp/.cache
ENV DOTNET_BUNDLE_EXTRACT_BASE_DIR=/tmp/.net
ENV PYTHONUNBUFFERED=1
ENV PORT=8080

EXPOSE 8080

CMD ["python3", "/mcp-server/mcp_proxy.py"]
