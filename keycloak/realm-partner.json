{
  "realm": "partner-agent",
  "displayName": "Partner Agent System",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "failureFactor": 30,
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "engineering",
        "description": "Engineering department"
      },
      {
        "name": "software",
        "description": "Software department"
      },
      {
        "name": "network",
        "description": "Network department"
      },
      {
        "name": "kubernetes",
        "description": "Kubernetes department"
      },
      {
        "name": "azure",
        "description": "Azure and ARO department"
      },
      {
        "name": "admin",
        "description": "Administration department"
      }
    ]
  },
  "groups": [
    {
      "name": "engineering",
      "path": "/engineering",
      "realmRoles": ["engineering"]
    },
    {
      "name": "software",
      "path": "/software",
      "realmRoles": ["software"]
    },
    {
      "name": "network",
      "path": "/network",
      "realmRoles": ["network"]
    },
    {
      "name": "kubernetes",
      "path": "/kubernetes",
      "realmRoles": ["kubernetes"]
    },
    {
      "name": "azure",
      "path": "/azure",
      "realmRoles": ["azure"]
    },
    {
      "name": "admin",
      "path": "/admin",
      "realmRoles": ["admin"]
    }
  ],
  "users": [
    {
      "username": "carlos",
      "firstName": "Carlos",
      "lastName": "Camacho",
      "email": "carlos@example.com",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "carlos123",
          "temporary": false
        }
      ],
      "realmRoles": ["engineering", "software", "kubernetes", "azure"],
      "groups": ["/engineering", "/software", "/kubernetes", "/azure"]
    },
    {
      "username": "luis",
      "firstName": "Luis",
      "lastName": "Arizmendi",
      "email": "luis@example.com",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "luis123",
          "temporary": false
        }
      ],
      "realmRoles": ["engineering", "network"],
      "groups": ["/engineering", "/network"]
    },
    {
      "username": "sharon",
      "firstName": "Sharon",
      "lastName": "Admin",
      "email": "sharon@example.com",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "sharon123",
          "temporary": false
        }
      ],
      "realmRoles": ["engineering", "software", "network", "kubernetes", "azure", "admin"],
      "groups": ["/engineering", "/software", "/network", "/kubernetes", "/azure", "/admin"]
    },
    {
      "username": "josh",
      "firstName": "Josh",
      "lastName": "Restricted",
      "email": "josh@example.com",
      "emailVerified": true,
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "josh123",
          "temporary": false
        }
      ],
      "realmRoles": [],
      "groups": []
    }
  ],
  "clients": [
    {
      "clientId": "partner-agent-ui",
      "name": "Partner Agent UI",
      "rootUrl": "",
      "baseUrl": "/",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:8000/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:8000/*"
      ],
      "webOrigins": ["+"],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "fullScopeAllowed": true,
      "defaultClientScopes": [],
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "email_verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "given_name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "claim.name": "given_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "family_name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "claim.name": "family_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "realm_roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "partner-agent-ui",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ]
}
